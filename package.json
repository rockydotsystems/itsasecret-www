{
  "name": "itsasecret-www",
  "version": "0.1.0",
  "private": true,
  "description": "itsasecret — Cloudflare Worker API + website (Hono)",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "wrangler types && tsc --noEmit",
    "db:apply": "wrangler d1 migrations apply itsasecret --local",
    "db:apply:remote": "wrangler d1 migrations apply itsasecret --remote",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.19.0",
    "@scalar/hono-api-reference": "^0.6.0",
    "hash-wasm": "^2.4.0",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
